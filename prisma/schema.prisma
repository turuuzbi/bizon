generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
}

enum AddressType {
  SHIPPING
  BILLING
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum UnitType {
  PIECE
  BOX
  BAG
  PACK
  SET
  PAIR
  METER
  CENTIMETER
  MILLIMETER
  SQUARE_METER
  CUBIC_METER
  LITER
  KILOGRAM
  GRAM
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  AUTHORIZED
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

enum FulfillmentStatus {
  UNFULFILLED
  PARTIAL
  FULFILLED
  RETURNED
  CANCELLED
}

enum OrderAddressType {
  SHIPPING
  BILLING
}

model User {
  id          String    @id @default(cuid())
  clerkUserId String    @unique
  email       String?   @unique
  firstName   String?
  lastName    String?
  phone       String?
  imageUrl    String?
  role        UserRole  @default(CUSTOMER)
  isActive    Boolean   @default(true)
  metadata    Json?
  addresses   Address[]
  cart        Cart?
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([createdAt])
}

model Address {
  id                   String       @id @default(cuid())
  userId               String
  type                 AddressType?
  label                String?
  recipientName        String?
  companyName          String?
  phone                String?
  countryCode          String       @default("MN")
  city                 String
  district             String?
  subDistrict          String?
  postalCode           String?
  line1                String
  line2                String?
  deliveryInstructions String?
  isDefault            Boolean      @default(false)
  metadata             Json?
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt

  @@index([userId, type])
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logoUrl     String?
  websiteUrl  String?
  isActive    Boolean   @default(true)
  metadata    Json?
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
}

model Category {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  description       String?
  imageUrl          String?
  parentId          String?
  sortOrder         Int               @default(0)
  isActive          Boolean           @default(true)
  seoTitle          String?
  seoDescription    String?
  metadata          Json?
  parent            Category?         @relation("CategoryChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children          Category[]        @relation("CategoryChildren")
  primaryProducts   Product[]         @relation("PrimaryCategory")
  productCategories ProductCategory[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@unique([parentId, name])
  @@index([parentId, sortOrder])
  @@index([isActive, sortOrder])
}

model Collection {
  id          String              @id @default(cuid())
  name        String              @unique
  slug        String              @unique
  description String?
  imageUrl    String?
  isActive    Boolean             @default(true)
  sortOrder   Int                 @default(0)
  metadata    Json?
  products    CollectionProduct[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([isActive, sortOrder])
}

model Product {
  id                String                 @id @default(cuid())
  name              String
  slug              String                 @unique
  sku               String?                @unique
  shortDescription  String?
  description       String?
  status            ProductStatus          @default(DRAFT)
  brandId           String?
  primaryCategoryId String?
  currency          String                 @default("MNT")
  baseUnit          UnitType               @default(PIECE)
  trackInventory    Boolean                @default(true)
  allowBackorder    Boolean                @default(false)
  isFeatured        Boolean                @default(false)
  isNewArrival      Boolean                @default(false)
  seoTitle          String?
  seoDescription    String?
  metadata          Json?
  publishedAt       DateTime?
  brand             Brand?                 @relation(fields: [brandId], references: [id], onDelete: SetNull)
  primaryCategory   Category?              @relation("PrimaryCategory", fields: [primaryCategoryId], references: [id], onDelete: SetNull)
  productCategories ProductCategory[]
  collections       CollectionProduct[]
  images            ProductImage[]
  options           ProductOption[]
  variants          ProductVariant[]
  specifications    ProductSpecification[]
  tags              ProductTag[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([brandId])
  @@index([primaryCategoryId])
  @@index([status, isFeatured, publishedAt])
  @@index([createdAt])
}

model ProductCategory {
  productId  String
  categoryId String
  sortOrder  Int      @default(0)
  assignedAt DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
}

model CollectionProduct {
  collectionId String
  productId    String
  sortOrder    Int        @default(0)
  assignedAt   DateTime   @default(now())
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([collectionId, productId])
  @@index([productId])
  @@index([collectionId, sortOrder])
}

model ProductImage {
  id        String          @id @default(cuid())
  productId String
  variantId String?
  url       String
  altText   String?
  position  Int             @default(0)
  isPrimary Boolean         @default(false)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())

  @@index([productId, position])
  @@index([variantId])
}

model ProductOption {
  id        String               @id @default(cuid())
  productId String
  name      String
  position  Int                  @default(0)
  product   Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  values    ProductOptionValue[]
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  @@unique([productId, name])
  @@index([productId, position])
}

model ProductOptionValue {
  id            String               @id @default(cuid())
  optionId      String
  value         String
  position      Int                  @default(0)
  option        ProductOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)
  variantValues VariantOptionValue[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([optionId, value])
  @@index([optionId, position])
}

model ProductVariant {
  id                String               @id @default(cuid())
  productId         String
  title             String
  sku               String?              @unique
  barcode           String?              @unique
  price             Decimal              @db.Decimal(12, 2)
  compareAtPrice    Decimal?             @db.Decimal(12, 2)
  costPrice         Decimal?             @db.Decimal(12, 2)
  inventoryQuantity Int                  @default(0)
  lowStockThreshold Int?
  trackInventory    Boolean              @default(true)
  allowBackorder    Boolean              @default(false)
  unitType          UnitType?
  unitValue         Decimal?             @db.Decimal(12, 3)
  unitLabel         String?
  minOrderQuantity  Decimal?             @db.Decimal(12, 3)
  maxOrderQuantity  Decimal?             @db.Decimal(12, 3)
  quantityStep      Decimal?             @db.Decimal(12, 3)
  weightGrams       Int?
  lengthMm          Int?
  widthMm           Int?
  heightMm          Int?
  imageUrl          String?
  isDefault         Boolean              @default(false)
  isActive          Boolean              @default(true)
  metadata          Json?
  product           Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  images            ProductImage[]
  optionValues      VariantOptionValue[]
  cartItems         CartItem[]
  orderItems        OrderItem[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@index([productId, isActive])
  @@index([productId, isDefault])
}

model VariantOptionValue {
  variantId     String
  optionValueId String
  variant       ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Cascade)
  optionValue   ProductOptionValue @relation(fields: [optionValueId], references: [id], onDelete: Cascade)

  @@id([variantId, optionValueId])
  @@index([optionValueId])
}

model ProductSpecification {
  id            String   @id @default(cuid())
  productId     String
  group         String?
  name          String
  value         String
  unit          String?
  position      Int      @default(0)
  isHighlighted Boolean  @default(false)
  isFilterable  Boolean  @default(false)
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([productId, position])
  @@index([name, value])
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  products  ProductTag[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model ProductTag {
  productId  String
  tagId      String
  assignedAt DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@index([tagId])
}

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique
  currency  String     @default("MNT")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model CartItem {
  id        String          @id @default(cuid())
  cartId    String
  productId String
  variantId String?
  quantity  Decimal         @db.Decimal(12, 3)
  unitPrice Decimal         @db.Decimal(12, 2)
  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([cartId])
  @@index([productId])
  @@index([variantId])
}

model Order {
  id                String            @id @default(cuid())
  orderNumber       String            @unique
  userId            String?
  status            OrderStatus       @default(PENDING)
  paymentStatus     PaymentStatus     @default(PENDING)
  fulfillmentStatus FulfillmentStatus @default(UNFULFILLED)
  currency          String            @default("MNT")
  subtotalAmount    Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount    Decimal           @default(0) @db.Decimal(12, 2)
  shippingAmount    Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount         Decimal           @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal           @default(0) @db.Decimal(12, 2)
  customerNote      String?
  internalNote      String?
  metadata          Json?
  placedAt          DateTime?
  paidAt            DateTime?
  fulfilledAt       DateTime?
  cancelledAt       DateTime?
  user              User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  addresses         OrderAddress[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([userId, createdAt])
  @@index([status, paymentStatus, fulfillmentStatus])
}

model OrderItem {
  id           String          @id @default(cuid())
  orderId      String
  productId    String?
  variantId    String?
  productName  String
  variantTitle String?
  sku          String?
  unitLabel    String?
  quantity     Decimal         @db.Decimal(12, 3)
  unitPrice    Decimal         @db.Decimal(12, 2)
  lineTotal    Decimal         @db.Decimal(12, 2)
  imageUrl     String?
  metadata     Json?
  order        Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant      ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  createdAt    DateTime        @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model OrderAddress {
  id                   String           @id @default(cuid())
  orderId              String
  type                 OrderAddressType
  recipientName        String
  companyName          String?
  phone                String?
  countryCode          String           @default("MN")
  city                 String
  district             String?
  subDistrict          String?
  postalCode           String?
  line1                String
  line2                String?
  deliveryInstructions String?
  order                Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  @@unique([orderId, type])
  @@index([orderId])
}
